# Anthropic Claude API key
ANTHROPIC_API_KEY=sk-ant-api03-...

# Supabase project URL and publishable/anon key
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=sb_publishable_...

# Optional: direct PostgreSQL connection string for faster bulk fetches (900k+ rows)
# Format: postgresql://postgres.<project-ref>:<db-password>@aws-0-ap-south-1.pooler.supabase.com:6543/postgres
# SUPABASE_DB_URL=postgresql://postgres.<ref>:<password>@...

# Password for the data upload page (analyst only)
UPLOAD_PASSWORD=your_upload_password_here
